# Firebase (obrigatório)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Cloud Functions - variáveis no Firebase Console (Configuração do projeto)

# Assistente IA (Gemini) - usado nas Cloud Functions (functions/.env)
# GEMINI_API_KEY=sua-chave-api-gemini

# Boleto Cora
# CORA_CLIENT_ID=client-id
# CORA_CLIENT_SECRET=client-secret
# CORA_API_URL=https://api.stage.cora.com.br (sandbox) ou https://api.cora.com.br (produção)

# Recibo por email (Gmail) - usado nas Cloud Functions (functions/.env)
# GMAIL_USER=apbcargaedescarga@gmail.com
# GMAIL_APP_PASSWORD=senha-de-app-16-caracteres

# NFS-e (NFE.io)
# NFE_IO_API_KEY=api-key
# NFE_IO_COMPANY_ID=company-id
# NFE_IO_SANDBOX=true (sandbox) ou false (produção)
